{
  "name": "skore-manager",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.mjs",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build:web": "tsc -b && vite build",
    "build:desktop": "tsc -b && vite build --mode desktop",
    "server": "node ./server/index.mjs",
    "dev:stack": "concurrently \"npm run server\" \"npm run dev\"",
    "start": "node ./server/index.mjs",
    "build": "npm run build:web",
    "preview": "vite preview",
    "sync:teams": "node ./scripts/sync-team-members.mjs",
    "desktop": "npm run build:desktop && electron .",
    "dist:win": "npm run build:desktop && electron-builder --win nsis"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.57.4",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "electron": "^35.1.5",
    "electron-builder": "^26.0.12",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  },
  "build": {
    "appId": "com.felipe.skoremanager",
    "productName": "Skore Manager",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
